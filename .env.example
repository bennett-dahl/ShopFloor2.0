# MongoDB (local or Atlas connection string)
MONGODB_URI=mongodb://localhost:27017/shopfloor

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-min-32-chars

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend (for "Request access" emails to admins). Get API key at https://resend.com
# No quotes; no spaces around =. Restart dev server after changing.
# RESEND_API_KEY=re_xxxx
# From address (optional; default uses Resend onboarding domain for testing)
# RESEND_FROM_EMAIL=Throttle Therapy Shop <noreply@yourdomain.com>
